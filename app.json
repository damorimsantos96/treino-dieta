{
  "expo": {
    "name": "Treino & Dieta",
    "slug": "treino-dieta",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "treinodieta",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f1014"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.diego.treinodieta"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f1014"
      },
      "package": "com.diego.treinodieta",
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.health.READ_WEIGHT",
        "android.permission.health.READ_HEALTH_DATA_IN_BACKGROUND"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png",
      "output": "single"
    },
    "updates": {
      "url": "https://u.expo.dev/baf0da1c-34c1-4e97-a621-96c2146928ae",
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "enabled": true
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "plugins": [
      "expo-router",
      "expo-local-authentication",
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 35,
            "buildToolsVersion": "36.0.0",
            "minSdkVersion": 26
          }
        }
      ],
      "expo-background-task",
      "expo-notifications",
      "expo-health-connect"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "supabaseUrl": "",
      "supabaseAnonKey": "",
      "router": {},
      "eas": {
        "projectId": "baf0da1c-34c1-4e97-a621-96c2146928ae"
      }
    },
    "owner": "damorimsantos96s-organization"
  }
}
